# Local development
DATABASE_URL=postgresql+psycopg://planner:planner@localhost:5432/planner

# Azure OpenAI — get from Azure AI Foundry > Deployments > your deployment > Keys & Endpoint
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_MAIN=gpt-4o
AZURE_OPENAI_DEPLOYMENT_FAST=gpt-4.1-nano

# App
APP_NAME=SJ Project Planner Agent
LOG_LEVEL=INFO
